{
  "name": "smartspend",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean --platform android",
    "prebuild:production": "expo prebuild --clean --platform android && node scripts/add-proguard-rules.js",
    "build:release": "cd android && .\\gradlew assembleRelease",
    "build:apk": "npm run prebuild:production && npm run build:release",
    "postinstall": "node scripts/add-proguard-rules.js || exit 0",
    "eas:build:dev": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform android",
    "eas:build:production": "eas build --profile production --platform android",
    "eas:dev": "eas build --profile development --platform android --local"
  },
  "dependencies": {
    "@expo-google-fonts/hanken-grotesk": "^0.4.3",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "~14.0.4",
    "@hookform/resolvers": "^3.9.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "expo": "~52.0.0",
    "expo-camera": "~16.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-font": "~13.0.0",
    "expo-image-manipulator": "~13.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linear-gradient": "~14.0.2",
    "expo-secure-store": "~14.0.0",
    "expo-sharing": "~13.0.1",
    "expo-sms": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.9",
    "react": "18.3.1",
    "react-hook-form": "^7.54.0",
    "react-native": "0.76.9",
    "react-native-chart-kit": "^6.12.0",
    "react-native-get-sms-android": "^2.1.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native-community/cli": "^20.2.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-chart-kit",
          "react-native-get-sms-android"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
