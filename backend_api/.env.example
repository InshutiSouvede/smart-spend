# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_TITLE=SmartSpend Backend API
APP_VERSION=1.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./smartspend.db

# ─── Storage paths ────────────────────────────────────────────────────────────
MODEL_DIR=./storage/models
USER_MODEL_DIR=./storage/user_models
UPLOAD_DIR=./storage/uploads
RETRAINING_JOB_DIR=./storage/retraining_jobs

# ─── Authentication ───────────────────────────────────────────────────────────
# Set MOCK_AUTH_ENABLED=true for local development without Supabase.
# Switch to false and supply Supabase credentials for any deployed environment.
MOCK_AUTH_ENABLED=true
MOCK_USER_ID=demo_user_001

# Supabase (required when MOCK_AUTH_ENABLED=false)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Keep CORS_ALLOW_CREDENTIALS=false when using wildcard origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006
CORS_ALLOW_CREDENTIALS=false

# ─── File uploads ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.pdf,.webp

# ─── OCR ──────────────────────────────────────────────────────────────────────
GOOGLE_VISION_ENABLED=false
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json

# ─── Machine Learning ─────────────────────────────────────────────────────────
MIN_CORRECTIONS_FOR_RETRAINING=5
